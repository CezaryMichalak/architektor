# Skopiuj do .env.local i uzupełnij kluczem z platform.openai.com
# Klucz jest używany WYŁĄCZNIE po stronie serwera Vite (plugin /api/analyze) — nigdy w przeglądarce.
OPENAI_API_KEY=your-openai-api-key-here

# Opcjonalnie — domyślnie gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Uruchomienie dev: npm run dev -- --port 3002
# Endpoint analizy AI: POST http://localhost:3002/api/analyze (wbudowany w Vite)
